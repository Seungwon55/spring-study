<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cos.springstudy.mapper.MemberMapper">
    <select id="selectByLoginId" parameterType="String" resultType="MemberDTO">
        SELECT *
        FROM member
        WHERE login_id = #{loginId}
    </select>

    <insert id="insert" parameterType="MemberDTO">
        INSERT INTO member(login_id, password, name, tel, email)
        VALUES(#{loginId}, #{password}, #{name}, #{tel}, #{email})
    </insert>
</mapper>